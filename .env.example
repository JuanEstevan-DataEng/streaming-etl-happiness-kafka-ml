# MySQL credentials (used by docker-compose and Python clients)
# ES: Credenciales MySQL (usadas por docker-compose y los clientes Python)
MYSQL_ROOT_PASSWORD=changeme_root
MYSQL_DATABASE=happiness
MYSQL_USER=happiness_app
MYSQL_PASSWORD=changeme_app
MYSQL_HOST=localhost
MYSQL_PORT=3307

# Kafka
# ES: Configuración de Kafka
KAFKA_BOOTSTRAP=localhost:9092
KAFKA_TOPIC=happiness-predictions

# Producer pacing (seconds between events)
# ES: Cadencia del producer (segundos entre eventos)
PRODUCER_DELAY_SECONDS=0.5

# Noise injection: fraction of corrupted events for invalidation testing
# ES: Inyección de ruido: fracción de eventos corruptos para probar validación
PRODUCER_NOISE_RATIO=0.05
